{
    "id": "template-vsl-script-writer",
    "name": "VSL Script Writer v2",
    "description": "Generate Video Sales Letter scripts with proper hook, story, offer, and close structure.",
    "category": "VIDEO",
    "status": "active",
    "version": "2.0.0",
    "nodes": [
        {
            "id": "trigger-1",
            "type": "manual-trigger",
            "position": {
                "x": 100,
                "y": 200
            },
            "data": {
                "label": "Start Script",
                "nodeType": "manual-trigger",
                "description": "Generate VSL script",
                "config": {
                    "requiredInputs": [
                        "icp_id",
                        "offer_id",
                        "target_length_minutes"
                    ]
                }
            }
        },
        {
            "id": "resolve-icp-1",
            "type": "resolve-icp",
            "position": {
                "x": 300,
                "y": 200
            },
            "data": {
                "label": "Select Target",
                "nodeType": "resolve-icp",
                "description": "Video audience",
                "config": {}
            }
        },
        {
            "id": "resolve-offer-1",
            "type": "resolve-offer",
            "position": {
                "x": 500,
                "y": 200
            },
            "data": {
                "label": "Select Offer",
                "nodeType": "resolve-offer",
                "description": "Product for VSL",
                "config": {}
            }
        },
        {
            "id": "resolve-angle-1",
            "type": "resolve-angle",
            "position": {
                "x": 700,
                "y": 200
            },
            "data": {
                "label": "Select Angle",
                "nodeType": "resolve-angle",
                "description": "Story angle",
                "config": {}
            }
        },
        {
            "id": "generate-1",
            "type": "generate-website-page",
            "position": {
                "x": 900,
                "y": 200
            },
            "data": {
                "label": "Generate VSL Script",
                "nodeType": "generate-website-page",
                "description": "Full VSL script with sections",
                "config": {
                    "pageType": "VSL_SCRIPT",
                    "provider": "openai",
                    "model": "gpt-4o",
                    "temperature": 0.8,
                    "structure": [
                        "hook",
                        "problem",
                        "story",
                        "solution",
                        "proof",
                        "offer",
                        "stack",
                        "guarantee",
                        "close",
                        "ps"
                    ]
                }
            }
        },
        {
            "id": "validate-1",
            "type": "validate-quality",
            "position": {
                "x": 1100,
                "y": 200
            },
            "data": {
                "label": "Claims Check",
                "nodeType": "validate-quality",
                "description": "Validate claims and compliance",
                "config": {
                    "minScore": 75,
                    "checkClaims": true,
                    "checkFTCCompliance": true
                }
            }
        },
        {
            "id": "output-store-1",
            "type": "output-store",
            "position": {
                "x": 1300,
                "y": 200
            },
            "data": {
                "label": "Store Script",
                "nodeType": "output-store",
                "description": "Save VSL script",
                "config": {
                    "table": "generated_scripts"
                }
            }
        }
    ],
    "edges": [
        {
            "id": "e1",
            "source": "trigger-1",
            "target": "resolve-icp-1",
            "animated": true
        },
        {
            "id": "e2",
            "source": "resolve-icp-1",
            "target": "resolve-offer-1",
            "animated": false
        },
        {
            "id": "e3",
            "source": "resolve-offer-1",
            "target": "resolve-angle-1",
            "animated": false
        },
        {
            "id": "e4",
            "source": "resolve-angle-1",
            "target": "generate-1",
            "animated": false
        },
        {
            "id": "e5",
            "source": "generate-1",
            "target": "validate-1",
            "animated": false
        },
        {
            "id": "e6",
            "source": "validate-1",
            "target": "output-store-1",
            "animated": true
        }
    ]
}
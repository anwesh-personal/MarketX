                "description": "Generate sales copy",
                "config": {
                    "requiredInputs": [
                        "icp_id",
                        "offer_id",
                        "copy_type"
                    ]
                }
            }
        },
        {
            "id": "resolve-icp-1",
            "type": "resolve-icp",
            "position": {
                "x": 300,
                "y": 200
            },
            "data": {
                "label": "Select Target",
                "nodeType": "resolve-icp",
                "description": "Target audience",
                "config": {}
            }
        },
        {
            "id": "resolve-offer-1",
            "type": "resolve-offer",
            "position": {
                "x": 500,
                "y": 200
            },
            "data": {
                "label": "Select Offer",
                "nodeType": "resolve-offer",
                "description": "Product/service to sell",
                "config": {}
            }
        },
        {
            "id": "resolve-angle-1",
            "type": "resolve-angle",
            "position": {
                "x": 700,
                "y": 200
            },
            "data": {
                "label": "Select Persuasion Angle",
                "nodeType": "resolve-angle",
                "description": "Primary persuasion axis",
                "config": {
                    "preferredAxis": "risk"
                }
            }
        },
        {
            "id": "generate-1",
            "type": "generate-website-page",
            "position": {
                "x": 900,
                "y": 200
            },
            "data": {
                "label": "Generate Sales Copy",
                "nodeType": "generate-website-page",
                "description": "Generate conversion-focused copy",
                "config": {
                    "pageType": "SALES_COPY",
                    "provider": "openai",
                    "model": "gpt-4o",
                    "temperature": 0.7,
                    "focus": "conversion"
                }
            }
        },
        {
            "id": "validate-1",
            "type": "validate-quality",
            "position": {
                "x": 1100,
                "y": 200
            },
            "data": {
                "label": "No-Hype Check",
                "nodeType": "validate-quality",
                "description": "Compliance and no-hype validation",
                "config": {
                    "minScore": 75,
                    "checkNoHype": true,
                    "checkClaims": true,
                    "rejectOnFail": true
                }
            }
        },
        {
            "id": "output-store-1",
            "type": "output-store",
            "position": {
                "x": 1300,
                "y": 200
            },
            "data": {
                "label": "Store Copy",
                "nodeType": "output-store",
                "description": "Save approved copy",
                "config": {
                    "table": "generated_copy"
                }
            }

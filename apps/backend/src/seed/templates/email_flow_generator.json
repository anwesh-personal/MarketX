{
    "id": "template-email-flow-generator",
    "name": "Email Flow Generator v2",
    "description": "Generate multi-email nurture sequences with soap opera structure. Creates 5-7 emails with progressive CTAs.",
    "category": "EMAIL",
    "status": "active",
    "version": "2.0.0",
    "nodes": [
        {
            "id": "trigger-1",
            "type": "manual-trigger",
            "position": {
                "x": 100,
                "y": 200
            },
            "data": {
                "label": "Start Generation",
                "nodeType": "manual-trigger",
                "description": "Manually triggered flow generation",
                "config": {
                    "requiredInputs": [
                        "icp_id",
                        "offer_id",
                        "email_count",
                        "flow_goal"
                    ]
                }
            }
        },
        {
            "id": "resolve-icp-1",
            "type": "resolve-icp",
            "position": {
                "x": 300,
                "y": 200
            },
            "data": {
                "label": "Select ICP",
                "nodeType": "resolve-icp",
                "description": "Resolve target audience segment from KB",
                "config": {}
            }
        },
        {
            "id": "resolve-offer-1",
            "type": "resolve-offer",
            "position": {
                "x": 500,
                "y": 200
            },
            "data": {
                "label": "Select Offer",
                "nodeType": "resolve-offer",
                "description": "Resolve offer to promote in sequence",
                "config": {}
            }
        },
        {
            "id": "resolve-angle-1",
            "type": "resolve-angle",
            "position": {
                "x": 700,
                "y": 200
            },
            "data": {
                "label": "Select Angle",
                "nodeType": "resolve-angle",
                "description": "Choose persuasion angle (speed, control, risk, etc.)",
                "config": {
                    "preferredAxis": "speed"
                }
            }
        },
        {
            "id": "resolve-bp-1",
            "type": "resolve-blueprint",
            "position": {
                "x": 900,
                "y": 200
            },
            "data": {
                "label": "Select Flow Blueprint",
                "nodeType": "resolve-blueprint",
                "description": "Get email flow structure from KB",
                "config": {
                    "contentType": "email_flow",
                    "flowGoal": "MEANINGFUL_REPLY"
                }
            }
        },
        {
            "id": "generate-1",
            "type": "generate-email-flow",
            "position": {
                "x": 1100,
                "y": 200
            },
            "data": {
                "label": "Generate Email Sequence",
                "nodeType": "generate-email-flow",
                "description": "Generate full email sequence with subject lines, bodies, and CTAs",
                "config": {
                    "provider": "openai",
                    "model": "gpt-4o",
                    "temperature": 0.8,
                    "defaultEmailCount": 5
                }
            }
        },
        {
            "id": "validate-1",
            "type": "validate-quality",
            "position": {
                "x": 1300,
                "y": 200
            },
            "data": {
                "label": "Validate Sequence",
                "nodeType": "validate-quality",
                "description": "Check quality and coherence of email sequence",
                "config": {
                    "minScore": 70,
                    "checkSequenceCoherence": true
                }
            }
        },
        {
            "id": "output-store-1",
            "type": "output-store",
            "position": {
                "x": 1500,
                "y": 150
            },
            "data": {
                "label": "Store Flow",
                "nodeType": "output-store",
                "description": "Save generated flow to database",
                "config": {
                    "table": "generated_email_flows",
                    "includeVersioning": true
                }
            }
        },
        {
            "id": "output-log-1",
            "type": "output-analytics",
            "position": {
                "x": 1500,
                "y": 280
            },
            "data": {
                "label": "Log Generation",
                "nodeType": "output-analytics",
                "description": "Track generation for analytics",
                "config": {}
            }
        }
    ],
    "edges": [
        {
            "id": "e1",
            "source": "trigger-1",
            "target": "resolve-icp-1",
            "animated": true
        },
        {
            "id": "e2",
            "source": "resolve-icp-1",
            "target": "resolve-offer-1",
            "animated": false
        },
        {
            "id": "e3",
            "source": "resolve-offer-1",
            "target": "resolve-angle-1",
            "animated": false
        },
        {
            "id": "e4",
            "source": "resolve-angle-1",
            "target": "resolve-bp-1",
            "animated": false
        },
        {
            "id": "e5",
            "source": "resolve-bp-1",
            "target": "generate-1",
            "animated": false
        },
        {
            "id": "e6",
            "source": "generate-1",
            "target": "validate-1",
            "animated": false
        },
        {
            "id": "e7",
            "source": "validate-1",
            "target": "output-store-1",
            "animated": true
        },
        {
            "id": "e8",
            "source": "validate-1",
            "target": "output-log-1",
            "animated": false
        }
    ]
}
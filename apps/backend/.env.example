# ============================================================
# AXIOM ENGINE - Backend Environment Variables
# Copy to .env and fill in values
# ============================================================

# --- Server ---
PORT=3001
NODE_ENV=development

# --- Database (Local Supabase — run `npx supabase status` to get keys) ---
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=<get from `npx supabase status` → service_role key>

# --- Redis (for BullMQ workers) ---
REDIS_URL=redis://localhost:6379

# --- AI Provider Keys ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- JWT ---
JWT_SECRET=local-dev-jwt-secret-change-in-production
SUPERADMIN_JWT_SECRET=local-dev-superadmin-secret-change-in-production

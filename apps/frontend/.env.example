# ============================================================
# AXIOM ENGINE - Frontend Environment Variables
# Copy to .env.local and fill in values
# ============================================================

# --- Supabase (run `npx supabase status` to get these values after `npm run local:up`) ---
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<get from `npx supabase status` → anon key>
SUPABASE_SERVICE_ROLE_KEY=<get from `npx supabase status` → service_role key>

# --- Backend API ---
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# --- AI Provider Keys (at least one required) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# --- Superadmin JWT ---
SUPERADMIN_JWT_SECRET=local-dev-superadmin-secret-change-in-production
